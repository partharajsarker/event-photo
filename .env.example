# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Database (Neon or Supabase PostgreSQL)
# =============================================================================
# Connection pooling URL (for serverless - use Neon's pooled connection or Supabase's pooler)
DATABASE_URL=postgresql://user:password@pooler.neon.tech/dbname?sslmode=require&pgbouncer=true

# Direct connection URL (for migrations - use Neon's direct connection)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# =============================================================================
# Cloudflare R2 Storage
# =============================================================================
# Get these from Cloudflare Dashboard > R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=event-photos

# Public URL for accessing stored files (custom domain or R2 public URL)
# Example: https://pub-xxx.r2.dev or https://your-custom-domain.com
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# =============================================================================
# Upstash Redis (Rate Limiting)
# =============================================================================
# Get these from Upstash Console (free tier available)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# Authentication (NextAuth.js)
# =============================================================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-at-least-32-chars

# The URL of your app (same as NEXT_PUBLIC_APP_URL)
NEXTAUTH_URL=http://localhost:3000

# Admin password for accessing the admin dashboard
ADMIN_PASSWORD=your-secure-admin-password

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_UPLOAD_MAX_REQUESTS=30

# =============================================================================
# Upload Limits
# =============================================================================
MAX_UPLOAD_SIZE_MB=50
