# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://eventphotos:eventphotos@localhost:5432/eventphotos?schema=public

# S3-compatible storage (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=event-photos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Admin API key (send as X-Admin-Key header for admin routes)
ADMIN_API_KEY=dev-admin-key-change-in-production

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
